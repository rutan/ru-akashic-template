{
  "type": "module",
  "name": "@rutan/akashic-template",
  "version": "1.0.0",
  "author": "ru_shalm <ru_shalm@hazimu.com>",
  "license": "Unlicense",
  "private": true,
  "scripts": {
    "start": "akashic-sandbox ./game",
    "serve": "akashic serve --target-service nicolive ./game",
    "build": "run-s lint clean build:*",
    "build:vite": "cross-env NODE_ENV=production vite build",
    "build:scan": "pnpm run scan",
    "watch": "run-p watch:*",
    "watch:vite": "cross-env NODE_ENV=development vite build -w --mode development",
    "watch:scan": "cross-env JITI_ESM_RESOLVE=1 jiti ./scripts/scanAsset.ts -w",
    "dev": "run-p start watch",
    "dev-serve": "run-p serve watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "assets": "run-s assets:* scan",
    "assets:mkdir": "mkdirp src/assets && mkdirp game/assets/textures",
    "assets:updateAssets": "cross-env JITI_ESM_RESOLVE=1 jiti ./scripts/convertAssets.ts",
    "scan": "cd game && akashic scan asset",
    "clean": "run-p clean:*",
    "clean:script": "rimraf ./game/script/bundle.js",
    "lint": "run-s lint:*",
    "lint:biome": "biome check ./",
    "lint:tsc": "tsc --noEmit",
    "format": "biome check --apply ./",
    "deploy:web": "cross-env JITI_ESM_RESOLVE=1 jiti ./scripts/buildForWeb.ts && deployment-zip -c .deployment-zip.ts -m zip ./tmp/_build",
    "deploy:nicolive": "cross-env JITI_ESM_RESOLVE=1 jiti ./scripts/archiveForNicoLive.ts",
    "prepare": "husky install",
    "precommit": "npm run lint"
  },
  "dependencies": {
    "@akashic-extension/akashic-hover-plugin": "^3.2.3",
    "@akashic-extension/resolve-player-info": "^1.3.0",
    "@akashic/akashic-engine": "^3.19.0",
    "eventmit": "^2.0.4"
  },
  "devDependencies": {
    "@akashic/akashic-cli": "^2.17.24",
    "@akashic/akashic-cli-commons": "^0.15.3",
    "@akashic/akashic-cli-export": "^1.9.19",
    "@akashic/akashic-cli-scan": "^0.17.7",
    "@akashic/akashic-engine-standalone": "^3.19.0",
    "@akashic/akashic-sandbox": "^0.28.23",
    "@biomejs/biome": "^1.9.4",
    "@rutan/deployment-zip": "^0.5.0",
    "@storybook/addon-actions": "^8.4.6",
    "@storybook/addon-essentials": "^8.4.6",
    "@storybook/addon-links": "^8.4.6",
    "@storybook/blocks": "^8.4.6",
    "@storybook/html": "^8.4.6",
    "@storybook/html-vite": "^8.4.6",
    "@types/node": "^22.10.1",
    "chokidar": "^4.0.1",
    "cpx2": "^8.0.0",
    "cross-env": "^7.0.3",
    "free-tex-packer-core": "^0.3.4",
    "glob": "^11.0.0",
    "husky": "^9.1.7",
    "jiti": "^2.4.1",
    "mkdirp": "^3.0.1",
    "npm-run-all2": "^7.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^6.0.1",
    "storybook": "^8.4.6",
    "typescript": "^5.7.2",
    "vite": "^6.0.1"
  },
  "packageManager": "pnpm@9.14.4"
}
